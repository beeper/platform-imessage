{
  "name": "@beeper/platform-imessage",
  "version": "0.13.1",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    "./*": "./dist/*.js",
    "./auth": "./dist/auth/index.js",
    "./info": "./dist/info.js",
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "binaries/**/*"
  ],
  "scripts": {
    "dev": "concurrently -P 'yarn build:scss --watch' 'yarn build:typescript --watch' 'yarn build:swift --debug --watch {@}'",
    "prepack": "yarn build",
    "lint:swift": "swiftlint --fix --format src",
    "lint": "yarn eslint src --ext ts,tsx,js,jsx --cache",
    "build": "turbo run build:swift build:applescript build:typescript build:scss",
    "build:scss": "sass -s compressed --no-source-map src/auth/auth.scss binaries/imessage-auth.css",
    "build:typescript": "tsc",
    "typecheck": "tsc --noEmit",
    "build:swift": "node --loader ts-node/esm src/SwiftServer/build-swift.ts",
    "build:applescript": "src/AppleScriptServer/build-as-server.sh",
    "hackily-install-binaries": "mv /Applications/Texts.app/Contents/Resources/app/build/platform-imessage{,-old}; ln -fs ${PWD}/binaries /Applications/Texts.app/Contents/Resources/app/build/platform-imessage"
  },
  "dependencies": {
    "@textshq/platform-sdk": "https://github.com/TextsHQ/platform-sdk#450f733b0d496b793ae6cab273759a1246ee6053",
    "clsx": "^1.2.1",
    "concurrently": "^9.1.2",
    "conf": "^13",
    "crc": "^4.1.1",
    "image-size": "^1.1.1",
    "lodash": "^4.17.21",
    "url-regex": "^5.0.0"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.3.5",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.11.29",
    "@textshq/eslint-config": "https://github.com/TextsHQ/eslint-config#main",
    "@types/eslint": "^8.4.10",
    "@types/jest": "^28.1.6",
    "@types/lodash": "^4.14.182",
    "@types/node": "20.17.19",
    "@types/react": "^17.0.38",
    "esbuild": "^0.19.2",
    "eslint": "^8.30.0",
    "jest": "^28.1.3",
    "node-gyp": "^11.0.0",
    "node-mac-permissions": "TextsHQ/node-mac-permissions.git",
    "node-swift": "https://github.com/slice/node-swift#skip/15_4-tls",
    "p-queue": "^8",
    "p-retry": "^6",
    "react": "^18",
    "sass": "^1.76.0",
    "ts-jest": "^28.0.7",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  },
  "os": [
    "darwin"
  ],
  "resolutions": {
    "node-gyp": "^10.0.1"
  },
  "peerDependencies": {
    "node-mac-permissions": "*",
    "p-queue": "^8",
    "p-retry": "^6",
    "react": "*"
  },
  "packageManager": "yarn@4.5.0"
}
