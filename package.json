{
  "name": "@textshq/platform-imessage",
  "version": "0.1.0",
  "main": "dist/index.js",
  "files": [
    "dist/**/*",
    "binaries/**/*"
  ],
  "scripts": {
    "prepack": "yarn build",
    "transpile-scss": "node-sass --output-style compressed src/auth/auth.scss binaries/imessage-auth.css",
    "build": "yarn transpile-scss; yarn tsc; yarn build-binaries",
    "swiftlint": "swiftlint --fix --format src",
    "lint": "yarn eslint src --ext ts,tsx,js,jsx --cache",
    "build-swift-server": "ts-node src/SwiftServer/build-swift-server.ts",
    "build-as-server": "src/AppleScriptServer/build-as-server.sh",
    "build-rust-server": "src/RustServer/build-rust-server.sh",
    "build-binaries": "yarn build-as-server; yarn build-rust-server; yarn build-swift-server",
    "hackily-install-binaries": "mv /Applications/Texts.app/Contents/Resources/app/build/platform-imessage{,-old} && ln -fs \"${PWD}/binaries\" /Applications/Texts.app/Contents/Resources/app/build/platform-imessage"
  },
  "husky": {
    "hooks": {}
  },
  "dependencies": {
    "@textshq/platform-sdk": "link:../platform-sdk",
    "bluebird": "^3.7.2",
    "clsx": "^1.1.1",
    "conf": "^8.0.0",
    "crc": "^4.1.0",
    "image-size": "^1.0.1",
    "lodash": "^4.17.21",
    "node-mac-permissions": "^2.2.0",
    "p-retry": "^4.4.0",
    "react": "https://github.com/TextsHQ/react-global-shim",
    "react-helmet": "^6.1.0",
    "url-regex": "^5.0.0",
    "zlib": "^1.0.5"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.3.5",
    "@textshq/eslint-config": "https://github.com/TextsHQ/eslint-config#main",
    "@textshq/platform-test-lib": "https://github.com/TextsHQ/platform-test-lib#main",
    "@types/bluebird": "^3.5.33",
    "@types/eslint": "^7.2.7",
    "@types/jest": "^27.0.2",
    "@types/lodash": "^4.14.168",
    "@types/react": "^17.0.38",
    "@types/react-helmet": "^6.1.5",
    "eslint": "^7.22.0",
    "husky": "^4.3.8",
    "jest": "^27.4.7",
    "node-sass": "^7.0.1",
    "node-swift": "https://github.com/kabiroberai/node-swift#d4d1973d9d87ebb068347da5a64409a4c3887065",
    "ts-jest": "^27.1.3",
    "ts-node": "^10.4.0",
    "typescript": "^4.5.5"
  },
  "os": [
    "darwin"
  ],
  "packageManager": "yarn@3.2.0"
}
