{
  "name": "@textshq/platform-imessage",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "yarn build || true",
    "build": "node-sass --output-style compressed src/auth.scss binaries/imessage-auth.css; yarn tsc",
    "lint": "yarn eslint src --ext ts,tsx,js,jsx --cache",
    "build-swift-server": "ts-node src/SwiftServer/build-swift-server.ts",
    "build-as-server": "src/AppleScriptServer/build-as-server.sh",
    "build-rust-server": "src/RustServer/build-rust-server.sh",
    "build-binaries": "yarn build-as-server; yarn build-rust-server; yarn build-swift-server"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn lint --fix || true"
    }
  },
  "dependencies": {
    "bluebird": "^3.7.2",
    "clsx": "^1.1.1",
    "conf": "^8.0.0",
    "crc": "^3.8.0",
    "lodash": "^4.17.21",
    "node-mac-permissions": "^2.2.0",
    "p-retry": "^4.4.0",
    "react": "https://github.com/TextsHQ/react-global-shim",
    "react-helmet": "^6.1.0",
    "use-force-update": "^1.0.7",
    "uuid": "^8.3.2",
    "zlib": "^1.0.5"
  },
  "devDependencies": {
    "@textshq/eslint-config": "https://github.com/TextsHQ/eslint-config",
    "@textshq/platform-sdk": "link:../platform-sdk",
    "@types/bluebird": "^3.5.33",
    "@types/eslint": "^7.2.7",
    "@types/lodash": "^4.14.168",
    "@types/react": "^17.0.3",
    "@types/uuid": "^8.3.0",
    "eslint": "^7.22.0",
    "husky": "^4.3.8",
    "node-sass": "^6.0.0",
    "node-swift": "https://github.com/kabiroberai/node-swift#607175badce65215cc890012b97e275d7ae150ba",
    "ts-node": "^10.2.1",
    "typescript": "^4.2.3"
  }
}
