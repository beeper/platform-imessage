{
  "$schema": "./node_modules/turbo/schema.json",
  "globalEnv": [
    "CI_PUBLISHING",
    "SENTRY_AUTH_TOKEN"
  ],
  "tasks": {
    "build:swift": {
      "inputs": [
        "!**/.DS_Store",
        "!src/SwiftServer/.build/**",
        "!src/SwiftServer/.swiftpm/**",
        "src/SwiftServer/**",
        "package.json"
      ],
      "outputs": [
        "binaries/*/SwiftServer.node"
      ]
    },
    "build:applescript": {
      "inputs": [
        "!**/.DS_Store",
        "!src/AppleScriptServer/Release/**",
        "!src/AppleScriptServer/AppleScriptServer.xcodeproj/project.xcworkspace/xcshareddata/**",
        "src/AppleScriptServer/**"
      ],
      "outputs": [
        "src/AppleScriptServer/Release/**",
        "binaries/*/AppleScriptServer"
      ]
    },
    "build:typescript": {
      "outputs": ["dist/**"]
    },
    "build:scss": {
      "inputs": ["src/**/*.scss"],
      "outputs": ["binaries/*.css"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
